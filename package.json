{
  "name": "verifiable-memory-mcp",
  "version": "0.1.2",
  "description": "Local-first, append-only, tamper-evident memory for AI agents via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "verifiable-memory-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "demo:reset": "bash demo/reset.sh",
    "demo:setup": "node demo/setup.mjs",
    "demo:run-agent": "node demo/run-agent.mjs",
    "demo:authorized-update": "node demo/authorized-update.mjs",
    "demo:delegate-sensitive-request": "node demo/delegate-sensitive-request.mjs",
    "demo:tamper": "python3 demo/tamper.py",
    "demo:export": "node demo/export.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT"
}
