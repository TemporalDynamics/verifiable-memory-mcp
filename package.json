{
  "name": "verifiable-memory-mcp",
  "version": "0.1.2",
  "description": "Local-first, append-only, tamper-evident memory for AI agents via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "verifiable-memory-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "demo:reset": "bash demo/reset.sh",
    "demo:scenario:reset": "bash demo/reset.sh && node demo/setup.mjs",
    "demo:setup": "node demo/setup.mjs",
    "demo:cycle": "node demo/agent-loop.mjs --once",
    "demo:agent-loop": "node demo/agent-loop.mjs",
    "demo:owner-update": "node demo/authorized-source-update.mjs",
    "demo:authorized-source-update": "node demo/authorized-source-update.mjs",
    "demo:prompt-injection": "node demo/prompt-injection.mjs",
    "demo:owner-approve": "node demo/owner-approve.mjs",
    "demo:owner-reject": "node demo/owner-reject.mjs",
    "demo:tamper": "python3 demo/tamper.py",
    "demo:cycle-after-tamper": "node demo/agent-loop.mjs --once",
    "demo:export": "node demo/export.mjs",
    "demo:verifier": "python3 -m http.server 4190 --bind 127.0.0.1",
    "demo:dashboard": "node demo/dashboard-server.mjs",
    "demo:publish-local": "node demo/dashboard-server.mjs 4190",
    "demo:telegram": "node demo/telegram-bot.mjs",
    "demo:e2e": "node demo/e2e.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@napi-rs/keyring": "^1.3.0",
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT"
}
